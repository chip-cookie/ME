# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (로컬 개발) — 앱 실행 시 자동으로 DB 파일 생성
DATABASE_URL=file:./data/db/jasos.db

# Turso cloud (옵션)
# DATABASE_URL=libsql://your-db.turso.io?authToken=YOUR_TOKEN

# ─── Gemini API ───────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 무료 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Groq API (선택 — Gemini 폴백) ───────────────────────────────────────────
# https://console.groq.com/keys
# GROK_API_KEY=gsk_...

# ─── 인증 ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-secret-in-production

# ─── 기업 분석 외부 API (선택) ────────────────────────────────────────────────
# DART_API_KEY=
# NPS_API_KEY=

# ─── 서버 ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
